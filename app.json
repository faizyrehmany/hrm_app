{
  "expo": {
    "name": "Dreams HRM",
    "slug": "hrm_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon/new_logo.png",
    "scheme": "hrmapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "permissions": [
      "location",
      "locationBackground"
    ],
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to track employee attendance",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to your location to track attendance in the background",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon/new_logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.dnthrm.hrm",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/new_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUseUsageDescription": "Allow Dreams HRM to access your location in the background to track attendance.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "./plugins/withForegroundService",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/new_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0a2329d7-5bfa-48cf-a548-e64d2b9a1e95"
      }
    }
  }
}